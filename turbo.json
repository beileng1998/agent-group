{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "PORT",
    "VITE_WS_URL",
    "VITE_DEV_SERVER_URL",
    "ELECTRON_RENDERER_PORT",
    "AGENT_GROUP_HOME",
    "AGENT_GROUP_DESKTOP_WS_URL",
    "AGENT_GROUP_BROWSER_USE_PIPE_PATH",
    "AGENT_GROUP_BROWSER_PERF",
    "AGENT_GROUP_PROVIDER_RUNTIME_IDLE_STOP_MS",
    "AGENT_GROUP_GROK_ACP_DEBUG",
    "AGENT_GROUP_WEB_SOURCEMAP",
    "AGENT_GROUP_SERVER_SOURCEMAP",
    "AGENT_GROUP_DESKTOP_SOURCEMAP",
    "AGENT_GROUP_MODE",
    "AGENT_GROUP_PORT",
    "AGENT_GROUP_NO_BROWSER",
    "AGENT_GROUP_AUTH_TOKEN",
    "AGENT_GROUP_LOG_WS_EVENTS",
    "AGENT_GROUP_HOST",
    "AGENT_GROUP_AUTO_BOOTSTRAP_PROJECT_FROM_CWD"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    }
  }
}
