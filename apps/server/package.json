    "@effect/platform-node": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "@opencode-ai/sdk": "^1.15.13",
    "@pierre/diffs": "^1.2.12",
    "@xterm/headless": "^6.0.0",
    "effect": "catalog:",
    "node-pty": "^1.1.0",
    "open": "^10.1.0",
    "tree-kill": "^1.2.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@agent-group/contracts": "workspace:*",
