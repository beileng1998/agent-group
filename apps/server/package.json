{
  "name": "@agent-group/server",
  "version": "0.6.3",
  "private": true,
  "description": "Local-first workspace for running multiple coding agents in one project.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
